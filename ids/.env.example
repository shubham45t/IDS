# Local detection blocklists (Comma separated)
MALICIOUS_IPS=192.168.1.100,10.0.0.50
SUSPICIOUS_PORTS=4444,31337,4445

# Threshold for traffic counts before flagging anomaly
ANOMALY_THRESHOLD=10

# Threat Intelligence API Configuration
THREAT_API_URL=https://api.abuseipdb.com/api/v2/check
API_KEY=your_abuseipdb_api_key_here

# Location for structured logs
LOG_FILE_PATH=/app/logs/alerts.json
